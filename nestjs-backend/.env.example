NODE_ENV=development

# MongoDB — Database per Service (same instance, separate databases)
MONGO_URI_USERS=mongodb://localhost:27017/usermodule_users
MONGO_URI_STAFF=mongodb://localhost:27017/usermodule_staff
MONGO_URI_ITEMS=mongodb://localhost:27017/usermodule_items

# Service Ports
GATEWAY_PORT=3000
AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=3001
USER_SERVICE_HOST=localhost
USER_SERVICE_PORT=3002
STAFF_SERVICE_HOST=localhost
STAFF_SERVICE_PORT=3003
ITEM_SERVICE_HOST=localhost
ITEM_SERVICE_PORT=3004

# JWT
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=8h
JWT_COOKIE_EXPIRES_IN=1

# CORS
CLIENT_ORIGIN=http://localhost:5173
