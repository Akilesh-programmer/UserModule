{
  "name": "usermodule-nestjs-backend",
  "version": "1.0.0",
  "private": true,
  "description": "UserModule NestJS Microservices Backend",
  "scripts": {
    "build": "nest build",
    "build:all": "nest build api-gateway && nest build auth-service && nest build admin-service && nest build master-service && nest build item-service",
    "start:all": "concurrently --kill-others --names gateway,auth,admin,master,item -c cyan,green,yellow,magenta,blue \"npm run start:gateway\" \"npm run start:auth\" \"npm run start:admin\" \"npm run start:master\" \"npm run start:item\"",
    "start:gateway": "nest start api-gateway --watch",
    "start:auth": "nest start auth-service --watch",
    "start:admin": "nest start admin-service --watch",
    "start:master": "nest start master-service --watch",
    "start:item": "nest start item-service --watch",
    "start:prod:all": "concurrently --kill-others \"node dist/apps/api-gateway/main\" \"node dist/apps/auth-service/main\" \"node dist/apps/admin-service/main\" \"node dist/apps/master-service/main\" \"node dist/apps/item-service/main\"",
    "seed": "ts-node -r tsconfig-paths/register seed.ts",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/microservices": "^10.4.15",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/platform-express": "^10.4.15",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
